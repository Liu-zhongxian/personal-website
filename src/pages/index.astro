---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Load projects from JSON (generated by fetch script)
let projects: Array<{
  name: string;
  description: string;
  url: string;
  stars: number;
  language: string | null;
  homepage: string | null;
}> = [];

try {
  const filePath = join(process.cwd(), 'src/content/projects.json');
  const raw = readFileSync(filePath, 'utf-8');
  projects = JSON.parse(raw).slice(0, 3);
} catch {
  // projects.json not yet generated
}
---

<BaseLayout title="首页">
  <Hero />

  {/* Latest Blog Posts */}
  <section class="mt-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">最新博客</h2>
      <a href="/blog/" class="text-accent text-sm">查看全部 →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {blogPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  {/* Featured Projects */}
  <section class="mt-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">开源项目</h2>
      <a href="/projects/" class="text-accent text-sm">查看全部 →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>

  {/* Recent Articles */}
  <section class="mt-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">最新文章</h2>
      <a href="/articles/" class="text-accent text-sm">查看全部 →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          originalUrl={article.data.originalUrl}
          category={article.data.category}
        />
      ))}
    </div>
  </section>
</BaseLayout>
