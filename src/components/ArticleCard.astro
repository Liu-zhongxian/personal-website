---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  originalUrl: string;
  category: string;
}

const { title, description, pubDate, originalUrl, category } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group p-6 bg-surface rounded-xl border border-border hover:border-accent/30 transition-all">
  <a href={originalUrl} target="_blank" rel="noopener noreferrer" class="block">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-2 py-0.5 bg-accent-light text-accent rounded text-xs">
        {category}
      </span>
      <time datetime={pubDate.toISOString()} class="text-sm text-text-secondary">
        {formattedDate}
      </time>
    </div>
    <h3 class="text-lg font-bold group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="text-text-secondary mt-2 text-sm line-clamp-2">
      {description}
    </p>
    <span class="inline-block mt-3 text-accent text-sm">
      阅读全文 ↗
    </span>
  </a>
</article>
