---
interface Props {
  name: string;
  description: string;
  url: string;
  stars: number;
  language: string | null;
  homepage: string | null;
}

const { name, description, url, stars, language, homepage } = Astro.props;
---

<article class="group p-6 bg-surface rounded-xl border border-border hover:border-accent/30 transition-all">
  <a href={homepage || url} target="_blank" rel="noopener noreferrer" class="block">
    <div class="flex items-start justify-between">
      <h3 class="text-lg font-bold group-hover:text-accent transition-colors">
        {name}
      </h3>
      <div class="flex items-center gap-1 text-text-secondary text-sm">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
          <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z" />
        </svg>
        {stars}
      </div>
    </div>
    <p class="text-text-secondary mt-2 text-sm line-clamp-2">
      {description}
    </p>
    {language && (
      <span class="inline-block mt-3 px-2 py-0.5 bg-accent-light text-accent rounded text-xs">
        {language}
      </span>
    )}
  </a>
</article>
