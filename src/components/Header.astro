---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '博客' },
  { href: '/projects/', label: '项目' },
  { href: '/articles/', label: '文章' },
  { href: '/about/', label: '关于' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border bg-surface sticky top-0 z-50">
  <nav class="mx-auto max-w-5xl px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-text hover:opacity-80">
      PersonalSite
    </a>
    <ul class="flex gap-6">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === href || currentPath === href.slice(0, -1)
                ? 'text-accent'
                : 'text-text-secondary hover:text-text',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
